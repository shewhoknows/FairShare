          "color": "#f472b6",
          "steps": [
            { "screen": "04", "transition": "profile tab" },
            { "screen": "17", "transition": "sign out" },
            { "screen": "01", "transition": "" }
          ]
        }
      ],
      "legend": {
        "title": "Loop rules",
        "items": [
          { "label": "FRIEND", "target": "Ledger-scoped add member uses BillBandit email" },
          { "label": "PROFILE", "target": "Profile screenshot is a placeholder until next capture" }
        ]
      }
    },
    {
      "title": "D. Two-person split and settlement payment",
      "subtitle": "Railway-tested path: seed/register friend, add that friend to the ledger, create a split expense, view simplified settlement, and record payment.",
