        { "screen": "06", "transition": "add friend" },
        { "screen": "11", "transition": "email found" },
        { "screen": "06", "transition": "add split" },
        { "screen": "10", "transition": "save" },
        { "screen": "06", "transition": "settle tab" },
        { "screen": "07", "transition": "tap row" },
        { "screen": "08", "transition": "mark paid" },
        { "screen": "07", "transition": "all square" }
      ]
    },
    {
      "title": "E. Finalization and final bill",
      "subtitle": "Admins can mark an open Railway ledger final. Final Bill can route back to the ledger history; finalized ledgers no longer behave like live-edit ledgers.",
      "steps": [
        { "screen": "06", "transition": "mark final" },
        { "screen": "09", "transition": "see all" },
        { "screen": "06b", "transition": "settle tab" },
        { "screen": "07", "transition": "" }
