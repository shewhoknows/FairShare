  "routes": [
    {
      "title": "A. Railway sign-in and landing",
      "subtitle": "Signed-out users enter the blue/cream welcome screen, verify OTP against Railway, then land on real trips or the empty trips state.",
      "rows": [
        {
          "label": "Returning account",
          "color": "#67e8f9",
          "steps": [
            { "screen": "01", "transition": "login" },
            { "screen": "12", "transition": "send code" },
            { "screen": "13", "transition": "verify OTP" },
            { "screen": "15", "transition": "restore" },
            { "screen": "04", "transition": "" }
          ]
        },
        {
          "label": "No existing ledgers",
          "color": "#34d399",
          "steps": [
            { "screen": "15", "transition": "empty account" },
            { "screen": "03", "transition": "" }
          ]
        },
        {
          "label": "Incomplete profile gate",
          "color": "#f59e0b",
          "steps": [
            { "screen": "13", "transition": "needs profile" },
            { "screen": "14", "transition": "save profile" },
            { "screen": "15", "transition": "ready" },
            { "screen": "04", "transition": "" }
          ]
        }
      ],
      "legend": {
        "title": "Auth evidence",
        "items": [
          { "label": "LIVE", "target": "testRailwayOTPAuthSignsIntoReceiptTrips passed against Railway" },
          { "label": "OTP", "target": "AuthStore calls /api/mobile/auth/otp/start and /verify" }
        ]
      }
    },
    {
      "title": "B. Railway ledger creation and entry CRUD",
      "subtitle": "The primary ledger workflow is now tested against Railway: create group, add entry, edit entry, delete entry, and return to empty ledger.",
      "steps": [
        { "screen": "04", "transition": "add ledger" },
        { "screen": "05", "transition": "open ledger" },
        { "screen": "06a", "transition": "add entry" },
        { "screen": "10", "transition": "save" },
        { "screen": "06", "transition": "edit/delete" },
        { "screen": "10", "transition": "delete" },
        { "screen": "06a", "transition": "" }
      ]
    },
    {
      "title": "C. Live ledger action loops",
      "subtitle": "Hub loops from Live Ledger. Hub screens repeat so the route stays traceable and avoids crossed connectors.",
      "rows": [
        {
          "label": "Add or edit expense",
          "color": "#67e8f9",
          "steps": [
            { "screen": "06", "transition": "add/edit" },
            { "screen": "10", "transition": "save" },
            { "screen": "06", "transition": "" }
          ]
        },
        {
